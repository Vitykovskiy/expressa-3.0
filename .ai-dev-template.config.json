{
  "config_version": 1,
  "language": {
    "documentation": "ru",
    "issues": "ru",
    "pull_requests": "ru",
    "comments": "ru",
    "commits": "ru",
    "labels": "ru"
  },
  "workflow": {
    "execution_mode": "autonomous",
    "issue_tracking": "github_issues",
    "project_tracking": "github_project"
  },
  "pull_requests": {
    "enabled": false,
    "review": {
      "required": false,
      "reviewers": "human",
      "agent_must_read_comments": false,
      "agent_must_reply_to_comments": false,
      "agent_must_apply_accepted_feedback": false
    }
  },
  "project_map": {
    "enabled": true
  },
  "github": {
    "required_token_scopes": ["repo", "project"],
    "recommended_token_scopes": ["read:org", "workflow"]
  },
  "architecture": {
    "use_fsd": false
  }
}
