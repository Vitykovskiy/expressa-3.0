# Stage-0 DevOps bootstrap contract.
# Copy to `.env` locally or populate from a secret-backed runtime env.
# Do not commit real values.

# Raw VPS access used only for DevOps bootstrap.
VPS_HOST=example.com
VPS_USER=root
VPS_PORT=22
VPS_PASSWORD=change-me
VPS_SSH_PRIVATE_KEY_PATH=
VPS_SSH_PRIVATE_KEY=

# Published staging contract produced during Stage 0.
# Use placeholders locally; real values live in GitHub Secrets and on the VPS runtime env.
TARGET_URL=http://example.com:8080
STAGING_FRONTEND_PORT=8080
STAGING_BACKEND_PORT=8081
STAGING_POSTGRES_DB=expressa_stage0
STAGING_POSTGRES_USER=expressa
STAGING_POSTGRES_PASSWORD=change-me
STAGING_SESSION_SECRET=change-me
STAGING_DISABLE_TG_AUTH=true
STAGING_ADMIN_TELEGRAM_ID=0
STAGING_CUSTOMER_BOT_TOKEN=stage0-placeholder
STAGING_BACKOFFICE_BOT_TOKEN=stage0-placeholder
